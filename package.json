{
  "name": "nocodb-meta-cli",
  "version": "0.1.0",
  "description": "CLI for NocoDB meta API v2/v3 with manifest-based schema apply workflows",
  "bin": {
    "noco-meta": "./bin/noco-meta.js"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint . --deny-warnings",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "start": "npm run build --silent && node ./bin/noco-meta.js",
    "test": "tsx --test test/**/*.test.ts",
    "knip": "knip",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run knip"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "knip": "^6.2.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
